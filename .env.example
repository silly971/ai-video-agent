# AI Video Agent desktop defaults

# Local desktop database. The packaged exe writes to the user's app-data folder;
# source runs use this relative SQLite file.
DATABASE_URL="file:./data/desktop.db"

# Desktop mode keeps files on disk and runs tasks inside the Next.js process.
DESKTOP_MODE=true
TASK_QUEUE_MODE=local
REDIS_DISABLED=true
STORAGE_TYPE=local
UPLOAD_DIR=./data/uploads

# Local app URLs.
NEXTAUTH_URL=http://127.0.0.1:3000
INTERNAL_APP_URL=http://127.0.0.1:3000

# Local secrets. `npm run desktop:env` replaces placeholders with random values.
NEXTAUTH_SECRET=please-change-this-to-a-random-string
CRON_SECRET=please-change-this-cron-secret
INTERNAL_TASK_TOKEN=please-change-this-task-token
API_ENCRYPTION_KEY=please-change-this-encryption-key

# Worker and watchdog defaults kept for compatibility with the original project.
WATCHDOG_INTERVAL_MS=30000
TASK_HEARTBEAT_TIMEOUT_MS=90000
QUEUE_CONCURRENCY_IMAGE=50
QUEUE_CONCURRENCY_VIDEO=50
QUEUE_CONCURRENCY_VOICE=20
QUEUE_CONCURRENCY_TEXT=50

# Billing is disabled for a personal desktop agent by default.
BILLING_MODE=OFF

# Logs.
LOG_UNIFIED_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DEBUG_ENABLED=false
LOG_AUDIT_ENABLED=true
LOG_SERVICE=waoowaoo
LOG_REDACT_KEYS=password,token,apiKey,apikey,authorization,cookie,secret,access_token,refresh_token

# Streaming task progress.
LLM_STREAM_EPHEMERAL_ENABLED=true

# Optional provider keys can be configured in the app settings UI after launch.
